{
  "expo": {
    "name": "Entrenador personal",
    "slug": "EntrenadorPersonal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/LOGO-SPLASH.png",
    "scheme": "Trainfo",
    "userInterfaceStyle": "automatic",
    "jsEngine": "jsc",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.trainfo.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "useNextNotificationsApi": true
    },
    "splash": {
      "image": "./assets/images/LOGO-SPLASH.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D47A1"
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "2459c6f3-abc3-447c-8f22-b447435af475"
      }
    },
    "plugins": [
      "expo-sqlite"
    ]
  }
}
